graph G {
    overlap=false;
    node [shape=circle, style=filled, fixedsize=true];
0[fillcolor=white, fontcolor=black, pos="0,2!"];
1[fillcolor=white, fontcolor=black, pos="0,0!"];
2[fillcolor=white, fontcolor=black, pos="1,1!"];
3[fillcolor=white, fontcolor=black, pos="2,1!"];
4[fillcolor=white, fontcolor=black, pos="3,2!"];
5[fillcolor=white, fontcolor=black, pos="3,0!"];
0 -- 1;
0 -- 2;
1 -- 2;
2 -- 3;
3 -- 4;
3 -- 5;
4 -- 5;
}
